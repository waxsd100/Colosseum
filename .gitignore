# ============================================================
# Colosseum .gitignore
# ============================================================

# --- IDE ---
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/
.idea_modules/
atlassian-ide-plugin.xml

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/
bin/

# --- Gradle ---
.gradle/
**/build/
build/
gradle-app.setting
.gradletasknamecache

# Avoid ignoring Gradle wrapper jar
!gradle-wrapper.jar

# --- Compiled / Package Files ---
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- Logs ---
*.log

# --- BlueJ ---
*.ctxt

# --- JVM crash logs ---
hs_err_pid*
replay_pid*

# --- OS: macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# --- OS: Linux ---
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- OS: Windows ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# --- Minecraft Development ---
run/
runs/

# --- Local Tool Config ---
.antigravitycli/

# --- Environment / Secrets ---
.env
*.local
